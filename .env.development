# =============================================================
# VARIABLES DE ENTORNO — DESARROLLO
# =============================================================
# URLs de los microservicios del backend SIGEDU. Las usa el
# proxy del dev-server de Vite (vite.config.js): el código del
# frontend llama rutas relativas /api/** y Vite las reenvía al
# microservicio correspondiente, evitando problemas de CORS.
# =============================================================

VITE_API_IDENTIDAD=http://localhost:8080
VITE_API_REUNIONES=http://localhost:8082
VITE_API_ACADEMICA=http://localhost:8083
VITE_API_CALENDARIO=http://localhost:8084
VITE_API_CONVIVENCIA=http://localhost:8085
VITE_API_GEOGRAFIA=http://localhost:8086
VITE_API_GESTION_ACADEMICA=http://localhost:8087
VITE_API_MATRICULA=http://localhost:8088
VITE_API_MENSAJERIA=http://localhost:8089
VITE_API_NOTAS=http://localhost:8090

# Prefijo opcional para producción (build). En dev se deja vacío
# para que las peticiones pasen por el proxy de Vite.
VITE_API_BASE_URL=
